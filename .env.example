# =============================================================================
# News Analyser — Konfiguration
# Kopiere diese Datei nach .env und trage deine Werte ein.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM-Backend
# -----------------------------------------------------------------------------
# Welches Backend soll verwendet werden?
# Optionen: openai | anthropic | cli | lm_studio | copilot | m365_copilot
LLM_PROVIDER=openai

# Modell-ID (abhängig vom Provider)
# openai:     gpt-4o | gpt-4o-mini | o3-mini
# anthropic:  claude-opus-4-7 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
# lm_studio:  Modell-ID aus LM Studio (z.B. llama-3.3-70b)
# cli/copilot/m365: wird vom Provider bestimmt, kann leer bleiben
OPENAI_MODEL=gpt-4o

# Sampling-Parameter
# LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=2048

# -----------------------------------------------------------------------------
# API-Keys (nur den Key des gewählten Providers eintragen)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GITHUB_TOKEN=ghp_...              # für LLM_PROVIDER=copilot
# M365_COPILOT_ACCESS_TOKEN=...     # für LLM_PROVIDER=m365_copilot

# LM Studio läuft lokal — kein Key erforderlich
# OPENAI_BASE_URL=http://localhost:1234/v1   # für LLM_PROVIDER=lm_studio

# -----------------------------------------------------------------------------
# Lokale Modelle
# -----------------------------------------------------------------------------
# spaCy-Modell für Anonymisierung (NER: Personen, Organisationen)
# Deutsch:   de_core_news_sm (schneller) | de_core_news_md (Standard) | de_core_news_lg (genauer)
# Englisch:  en_core_web_md | en_core_web_lg
# SPACY_MODEL=de_core_news_md

# Sentence-Transformer-Modell für ChromaDB-Embeddings (semantische Suche)
# Deutsch:        paraphrase-multilingual-MiniLM-L12-v2 (Standard, auch mehrsprachig)
# Englisch:       all-MiniLM-L6-v2 (schnell) | all-mpnet-base-v2 (genauer)
# Mehrsprachig:   paraphrase-multilingual-MiniLM-L12-v2 | paraphrase-multilingual-mpnet-base-v2
# EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# -----------------------------------------------------------------------------
# Performance / Stabilität
# -----------------------------------------------------------------------------
TOKENIZERS_PARALLELISM=false   # Verhindert CPU-Deadlock beim Laden des Embedding-Modells (macOS)

# -----------------------------------------------------------------------------
# Feature-Flags
# -----------------------------------------------------------------------------
# SUBMIT_ENABLED=true    # false = kein "Einreichen"-Menü (Mac Mini Viewer-Modus)

# -----------------------------------------------------------------------------
# Feed-Konfiguration (RSS-Watcher)
# -----------------------------------------------------------------------------
# FEED_MODE=auto             # manual (Standard) | auto (Dauerbetrieb)
# FEED_INTERVAL=3600         # Sekunden zwischen automatischen Runs
# FEED_MAX_ARTICLES=20       # max. neue Artikel pro Lauf
# FEED_FILE=config/feeds.txt  # Pfad zur Feed-Liste (Standard)

# Themenfilter: Komma-getrennte Themen (Standard: Politik,Außenpolitik,Wirtschaft,Gesellschaft,Justiz)
# FEED_TOPICS=all            # Themenfilter deaktivieren, alle Artikel analysieren
# FEED_TOPICS=Politik,Wirtschaft
# Verfügbare Themen: Politik | Außenpolitik | Wirtschaft | Gesellschaft |
#                    Justiz | Gesundheit | Klima | Kultur | Technologie
