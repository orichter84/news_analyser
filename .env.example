# Copy to .env and fill in your values
OPENAI_API_KEY=sk-...

# Optional – use a specific model (default: gpt-4o)
# OPENAI_MODEL=gpt-4o-mini

# Optional – point to a local Ollama instance instead of OpenAI
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3.1

# Feed-Konfiguration
# FEED_MODE=auto                  # manual | auto
# FEED_INTERVAL=3600              # Sekunden zwischen Runs
# FEED_MAX_ARTICLES=20            # max. neue Artikel pro Lauf
# FEED_TOPICS=Politik,Außenpolitik,Wirtschaft,Gesellschaft,Justiz
#   Komma-getrennte Themen die analysiert werden (Standard: die 5 oben)
#   FEED_TOPICS=all  →  Themenfilter deaktiviert, alle Artikel analysieren
#   Verfügbare Themen: Politik | Außenpolitik | Wirtschaft | Gesellschaft |
#                      Justiz | Gesundheit | Klima | Kultur | Technologie
